# ─── AgilesTest — Variables d'environnement Production ───────────────────
# Copier ce fichier en .env et adapter les valeurs.
# Usage : docker compose -f docker-compose.prod.yml --env-file .env up -d
# ─────────────────────────────────────────────────────────────────────────

# ── Général ──────────────────────────────────────────────────────────────
TAG=latest
REGISTRY=
DOMAIN=agilestest.orange.ci

# ── Proxy ────────────────────────────────────────────────────────────────
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# ── Frontend ─────────────────────────────────────────────────────────────
VITE_APP_TITLE=AgilesTest
VITE_API_BASE_URL=/api
VITE_DATASET_STORAGE_MODE=local

# ── Orchestration ────────────────────────────────────────────────────────
JWT_SECRET=CHANGE-ME-GENERATE-A-STRONG-SECRET

# ── MinIO ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE-ME-STRONG-PASSWORD
MINIO_BUCKET=agilestest-artifacts

# ── Runner Agent ─────────────────────────────────────────────────────────
RUNNER_ID=runner-prod-01
POLL_INTERVAL_MS=5000
PROBE_TOKEN=

# ── SMS Orange (optionnel) ───────────────────────────────────────────────
# ORANGE_SMS_BASE_URL=https://api.orange.com/smsmessaging/v1
# ORANGE_SMS_TOKEN_URL=https://api.orange.com/oauth/v1/token
# ORANGE_SMS_CLIENT_ID=
# ORANGE_SMS_CLIENT_SECRET=
# ORANGE_SMS_SENDER_ID=AgilesTest

# ── SMTP (optionnel) ────────────────────────────────────────────────────
# SMTP_HOST=smtp.orange.ci
# SMTP_PORT=587
# SMTP_SECURITY=STARTTLS
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@agilestest.io
# SMTP_FROM_NAME=AgilesTest

# ── TLS (optionnel) ─────────────────────────────────────────────────────
# Placer les certificats dans deploy/compose/nginx/certs/
# TLS_CERT_PATH=./nginx/certs/fullchain.pem
# TLS_KEY_PATH=./nginx/certs/privkey.pem
