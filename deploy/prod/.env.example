# ============================================================================
# AgilesTest — Production Environment Variables
# ============================================================================

# ── MySQL Database ──────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_DATABASE=agilestest
MYSQL_USER=agilestest
MYSQL_PASSWORD=agilestest123
MYSQL_PORT=3307

# ── MinIO (S3-compatible storage) ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=miniopass123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=agilestest-artifacts
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# ── Application ─────────────────────────────────────────────────────────────
APP_PORT=8080
NODE_ENV=production
LOG_LEVEL=info
METRICS_ENABLED=true

# ── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=generer_un_secret_ici
CORS_ORIGIN=http://localhost:8080

# ── Frontend ────────────────────────────────────────────────────────────────
VITE_APP_TITLE=AgilesTest

# ── Retention (days) ────────────────────────────────────────────────────────
RETENTION_DAYS_ARTIFACTS=90
RETENTION_DAYS_RUNS=180
RETENTION_DAYS_SESSIONS=30
OWNER_OPEN_ID=admin_6abfb80d-d45b-4766-96c9-3c7bd4a5d606
OWNER_NAME=Administrateur
VITE_APP_ID=agilestest-local

# ── Keycloak Configuration ──────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=agilestest
KEYCLOAK_CLIENT_ID=agilestest-app
KEYCLOAK_CLIENT_SECRET=agilestest-secret
KEYCLOAK_DB=keycloak
APP_URL=http://localhost:8080

# ── Google OAuth (via Keycloak Identity Provider) ───────────────────────────
# Obtenir les identifiants sur https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
ENCRYPTION_MASTER_KEY=generer_une_cle_ici
