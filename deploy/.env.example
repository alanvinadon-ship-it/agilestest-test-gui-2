# ─── AgilesTest Production Docker Compose Configuration ──────────────────────
# Copy this file to .env and update values for your environment
# NEVER commit .env to version control

# ─── Database Configuration ───────────────────────────────────────────────────
# PostgreSQL connection parameters
DB_HOST=postgres
DB_PORT=5432
DB_USER=agilestest
DB_PASSWORD=agilestest_prod_secret_change_me
DB_NAME=agilestest_prod

# ─── JWT Configuration ────────────────────────────────────────────────────────
# Used for signing and verifying JWT tokens
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-prod-openssl-rand-base64-32
JWT_EXPIRES_IN=24h

# ─── MinIO S3-Compatible Storage ──────────────────────────────────────────────
# Credentials for MinIO (artifact storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_prod_secret_change_me
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=agilestest-artifacts
MINIO_DRIVE_BUCKET=agilestest-drive

# ─── Application Configuration ────────────────────────────────────────────────
# Environment mode
NODE_ENV=production

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Base URL for API calls (used by frontend and services)
BASE_URL=http://localhost

# Frontend configuration
VITE_APP_TITLE=AgilesTest
VITE_APP_LOGO=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
VITE_OAUTH_PORTAL_URL=

# ─── API Endpoints (internal, for service-to-service communication) ──────────
# These are used by services to communicate with each other
ADMIN_API_URL=http://admin-api:3001
REPOSITORY_API_URL=http://repository-api:3002
ORCHESTRATION_API_URL=http://orchestration-api:3003
COLLECTOR_API_URL=http://collector-api:3004
ANALYSIS_API_URL=http://analysis-api:3005
REPORTING_API_URL=http://reporting-api:3006
RUNNER_ENDPOINT=http://runner:4000

# ─── File Upload Configuration ────────────────────────────────────────────────
# Maximum upload size for artifacts
MAX_UPLOAD_SIZE=500m

# ─── Optional: SMTP Configuration (for notifications) ───────────────────────
# If you want to enable email notifications
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@agilestest.io
SMTP_PASSWORD=
SMTP_FROM=AgilesTest <noreply@agilestest.io>
SMTP_USE_TLS=true

# ─── Optional: Kubernetes Runner Configuration ─────────────────────────────
# If using Kubernetes for test execution
K8S_API_SERVER=https://kubernetes.example.com:6443
K8S_API_TOKEN=
K8S_NAMESPACE=agilestest-runners
K8S_IMAGE=agilestest/runner:latest

# ─── Optional: SSH Probe Configuration ──────────────────────────────────────
# For SSH-based probes
SSH_KEY_PATH=./deploy/certs/ssh_key
SSH_KEY_PASSPHRASE=

# ─── Optional: Monitoring & Observability ──────────────────────────────────
# Prometheus metrics endpoint
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Jaeger tracing
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ─── Optional: Backup Configuration ────────────────────────────────────────
# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=agilestest-backups
