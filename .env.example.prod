# ============================================================================
# AgilesTest — Production Environment Variables
# Copy to .env.prod and fill in your values
# ============================================================================

# ── MySQL Database ──────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_DATABASE=agilestest
MYSQL_USER=agilestest
MYSQL_PASSWORD=changeme_db_password
MYSQL_PORT=3306

# ── MinIO (S3-compatible storage) ───────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=agilestest-artifacts
S3_REGION=us-east-1
# Public URL for signed download URLs (accessible from browser)
S3_PUBLIC_URL=http://localhost:9000

# ── Application ─────────────────────────────────────────────────────────────
APP_PORT=80
NODE_ENV=production
LOG_LEVEL=info
METRICS_ENABLED=true

# ── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_min_32_chars
VITE_APP_ID=your_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im
OWNER_OPEN_ID=your_owner_open_id
OWNER_NAME=your_owner_name

# ── Forge API (Manus built-in services) ─────────────────────────────────────
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im

# ── Frontend ────────────────────────────────────────────────────────────────
VITE_APP_TITLE=AgilesTest
VITE_APP_LOGO=

# ── Retention (days) ────────────────────────────────────────────────────────
RETENTION_DAYS_ARTIFACTS=90
RETENTION_DAYS_RUNS=180
RETENTION_DAYS_SESSIONS=30

# ── Security ────────────────────────────────────────────────────────────────
# CORS_ORIGIN=https://your-domain.com
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# METRICS_BASIC_AUTH_USER=prometheus
# METRICS_BASIC_AUTH_PASSWORD=changeme_metrics_password
